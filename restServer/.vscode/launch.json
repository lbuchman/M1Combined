{
    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Run Tests (node:test)",
            "runtimeExecutable": "node",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "--test"
            ],
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch REST Server",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "PORT": "3300",
                "HOST": "127.0.0.1",
                "M1TFC_CMD": "node",
                "M1TFC_BASE_ARGS": "/home/lenel/myGitHub/M1Combined/m1tfc/bin/m1tfc.js",
                "M1TFC_CWD": "/home/lenel/myGitHub/M1Combined/m1tfc",
                "SNAP_DATA": "/home/lbuchman/snap_data",
                "SNAP_COMMON": "/home/lbuchman/snap_common"
            },
            "program": "${workspaceFolder}/src/server.js",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run npm test",
            "runtimeExecutable": "npm",
            "cwd": "${workspaceFolder}",
            "args": [
                "test"
            ],
            "console": "integratedTerminal"
        }
    ]
}