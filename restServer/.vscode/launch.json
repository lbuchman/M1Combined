{
    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Run Tests (node:test)",
            "runtimeExecutable": "node",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "--test"
            ],
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch REST Server",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/server.js",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run npm test",
            "runtimeExecutable": "npm",
            "cwd": "${workspaceFolder}",
            "args": [
                "test"
            ],
            "console": "integratedTerminal"
        }
    ]
}