{
    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Run Tests (node:test)",
            "runtimeExecutable": "node",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "--test"
            ],
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch REST Server",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "PORT": "3300",
                "HOST": "0.0.0.0",
                "SNAP_DATA": "/home/lenel/snap_data",
                "SNAP_COMMON": "/home/lenel/snap_common"
            },
            "program": "${workspaceFolder}/src/server.js",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run npm test",
            "runtimeExecutable": "npm",
            "cwd": "${workspaceFolder}",
            "args": [
                "test"
            ],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "attach",
            "name": "Attach Snap Debugger",
            "address": "127.0.0.1",
            "port": 9229,
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}