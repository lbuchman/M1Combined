{
  "files.exclude": {
    "**/.git": true,
    "**/.gitignore": false,
    "**/*.dbg": true,
    "**/*.o": true,
    "**/lib/": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/lib/": true
  },
  "files.associations": {
    "*.pas": "pascal",
    "*.lfm": "xml",
